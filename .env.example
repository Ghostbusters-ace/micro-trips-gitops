# ==============================================================================
# CONFIGURATION DES SECRETS (Micro-Trips Local-First)
# Copiez ce fichier sous le nom '.env.local' et modifiez les valeurs si besoin.
# ==============================================================================

# 1. Bases de données PostgreSQL (Catalog API & Booking API)
POSTGRES_USER=admin_micro_trips
POSTGRES_PASSWORD=super_secret_pg_password_123

# 2. Message Broker (RabbitMQ pour les événements asynchrones)
RABBITMQ_USER=rabbit_admin
RABBITMQ_PASSWORD=super_secret_mq_password_456

# 3. Serveur SMTP (MailHog en local)
SMTP_USER=dummy_user
SMTP_PASSWORD=dummy_password

# 4. Jeton de kubecost
KUBECOST_TOKEN=votre_jeton_gratuit_kubecost_789